# Copier vers .env.local puis adapter.

# Base SQLite locale
DATABASE_URL="file:./dev.db"

# Clé de signature des sessions JWT — générer avec :
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="change-me"

# Serveur d'inférence Ollama (déployé par l'INFRA)
# Depuis un autre PC du groupe : http://<IP-INFRA>:11434  (ex. http://10.15.2.23:11434)
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL_FINANCE="phi35-financial"
# Modèle médical provisoire (à brancher plus tard) :
OLLAMA_MODEL_MEDICAL="phi3.5"

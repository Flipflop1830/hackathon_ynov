# Copier vers .env.local puis adapter.

# Base SQLite locale
DATABASE_URL="file:./dev.db"

# Clé de signature des sessions JWT — générer avec :
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="change-me"

# Cookie de session Secure ? Laisser false en HTTP (LAN). true UNIQUEMENT derrière HTTPS.
# COOKIE_SECURE="false"

# ── Backend d'inférence : "ollama" ou "triton" ──────────────────────────────
INFERENCE_BACKEND="ollama"

# Si INFERENCE_BACKEND=triton (API v2, ex. serveur du groupe) :
TRITON_URL="http://10.82.119.69:8000"
TRITON_MODEL="phi35_financial"

# Si INFERENCE_BACKEND=ollama (API native, déployée par l'INFRA) :
# Depuis un autre PC : http://<IP-INFRA>:11434
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL_FINANCE="phi35-financial"
# 2e IA (modèle médical dédié, créé depuis ollama_server/Modelfile.medical) :
OLLAMA_MODEL_MEDICAL="phi35-medical"

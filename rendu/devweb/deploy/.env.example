# Variables lues par docker-compose (substitution ${...}).
# deploy.ps1 génère ce fichier automatiquement s'il est absent.

# Clé de signature des sessions JWT (32 octets base64) :
#   PowerShell : $b=New-Object byte[] 32; [Security.Cryptography.RandomNumberGenerator]::Fill($b); [Convert]::ToBase64String($b)
AUTH_SECRET="change-me"
